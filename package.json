{
  "name": "wemos-d1-pro",
  "version": "1.0.0",
  "description": "Aplikasi kontrol Wemos D1 dengan alarm dan notifikasi real-time",
  "main": "index.js",
  "scripts": {
    "start": "cordova serve",
    "build": "cordova build android --release",
    "build:debug": "cordova build android --debug",
    "run": "cordova run android",
    "run:debug": "cordova run android --debug",
    "prepare": "cordova prepare",
    "clean": "cordova clean",
    "plugin:add:all": "npm run plugin:add:notifications && npm run plugin:add:network && npm run plugin:add:audio",
    "plugin:add:notifications": "cordova plugin add cordova-plugin-local-notifications cordova-plugin-wake-lock cordova-plugin-background-mode cordova-plugin-vibration",
    "plugin:add:network": "cordova plugin add cordova-plugin-network-information cordova-plugin-wifiwizard2",
    "plugin:add:audio": "cordova plugin add cordova-plugin-media",
    "plugin:add:storage": "cordova plugin add cordova-plugin-file cordova-plugin-file-transfer cordova-sqlite-storage cordova-plugin-secure-storage",
    "plugin:list": "cordova plugin list",
    "platform:add": "cordova platform add android@latest",
    "check:requirements": "cordova requirements android",
    "sign:apk": "cd platforms/android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "cordova": "^12.0.0",
    "cordova-android": "^13.0.0"
  },
  "devDependencies": {
    "cordova-plugin-splashscreen": "~6.0.0",
    "cordova-plugin-statusbar": "~2.4.3",
    "cordova-plugin-device": "~2.1.0",
    "cordova-plugin-whitelist": "~1.3.4",
    "cordova-plugin-local-notifications": "~14.1.1",
    "cordova-plugin-wake-lock": "~1.0.1",
    "cordova-plugin-background-mode": "~0.7.3",
    "cordova-plugin-vibration": "~3.1.2",
    "cordova-plugin-network-information": "~3.0.0",
    "cordova-plugin-wifiwizard2": "~2.2.10",
    "cordova-plugin-media": "~6.0.0",
    "cordova-plugin-file": "~8.0.0",
    "cordova-plugin-file-transfer": "~1.7.1",
    "cordova-sqlite-storage": "~6.1.0",
    "cordova-plugin-secure-storage": "~3.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "author": "Wemos Development Team",
  "license": "MIT"
}
